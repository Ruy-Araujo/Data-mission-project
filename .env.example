# DataMission API
DATAMISSION_API_BASE_URL=https://api.datamission.com.br
DATAMISSION_API_TOKEN=<your-api-token>
DATAMISSION_PROJECT_ID=<your-project-id>
DATAMISSION_TIMEOUT_SECONDS=30
DATAMISSION_MAX_RETRIES=3
DATAMISSION_RESPONSE_FORMAT=csv
DATAMISSION_EXPECTED_COLUMNS=source_record_id
DATAMISSION_REQUIRED_NON_NULL_COLUMNS=source_record_id
DATAMISSION_STRICT_VALIDATION=false

# MinIO local
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<your-access-key>
MINIO_SECRET_KEY=<your-secret-key>
MINIO_BUCKET=raw
MINIO_RAW_BUCKET=raw
MINIO_SILVER_BUCKET=silver
MINIO_SECURE=false
MINIO_REGION=us-east-1

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=<your-postgres-db>
POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_STAGING_SCHEMA=staging
POSTGRES_STAGING_TABLE=datamission_records_raw
POSTGRES_INGESTION_HISTORY_TABLE=datamission_ingestion_history
POSTGRES_SILVER_SCHEMA=silver

# Airflow
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Runtime
EXTRACTOR_NAME=datamission_roterization
SOURCE_NAME=datamission
OUTPUT_PREFIX=datamission_roterization
LOG_LEVEL=INFO
